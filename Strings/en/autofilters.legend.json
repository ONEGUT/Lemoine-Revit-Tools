// autofilters.legend.json — Filter Legend Creator tool + handler logs.
// Command: (Auto Filters legend) / AutoFiltersLegendEventHandler.
{
  "title": "Filter Legend Creator",
  "runLabel": "Create Legend →",

  "steps": {
    "S1": "Review & Run"
  },

  "summaries": {
    "S1": "Ready to run"
  },

  "labels": {
    "legendName":  "Filter Color Legend",        // name of the created legend view
    "legendNameN": "Filter Color Legend ({0})"   // {0} = disambiguating number when the name is taken
  },

  "review": {
    "itemSource":   "Source",
    "itemOutput":   "Output",
    "itemGrouping": "Grouping",
    "itemSwatches": "Swatches",

    "source":   "Active view filters",
    "output":   "New legend view",
    "grouping": "By discipline prefix",
    "swatches": "One per unique color",
    "note":     "Reads all filter overrides from the active view and creates a new legend view with colored swatches and label text, grouped by discipline. Requires at least one existing legend view in the project."
  },

  "log": {
    "raising":     "Raising Revit external event…",
    "error":       "Error: {0}",
    "noOverrides": "Active view '{0}' does not support graphic overrides.",   // {0} = view name
    "noFilters":   "No filters applied to '{0}'. Run Auto Filters first.",    // {0} = view name
