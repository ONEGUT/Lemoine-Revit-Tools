    "noLegend":    "No legend view found in project. Create one in Revit (View → New Legend), then re-run.",
    "missingType": "Missing required project element (FilledRegionType or TextNoteType).",
    "dupFailed":        "Failed to duplicate the template legend view.",
    "swatchTypeFailed": "Swatch type failed: {0}",   // {0} = error
    "swatchFailed":     "Swatch '{0}': {1}",          // {0}=value {1}=error
    "created":          "Created legend view '{0}' — {1} swatch row(s) drawn across {2} group(s), {3} failed."
  }
}
