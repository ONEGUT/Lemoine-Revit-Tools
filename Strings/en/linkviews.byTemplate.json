    "skipEmpty":  "Skip '{0}' × '{1}' — empty name.",          // {0}=view {1}=template
    "skipExists": "Skip '{0}' (name already exists).",
    "skipNoDup":  "Skip '{0}' — view cannot be duplicated.",
    "created":    "Created '{0}'  ({1})",                       // {0}=name {1}=template
    "failed":     "Failed '{0}' × '{1}': {2}",                  // {0}=view {1}=template {2}=error
    "complete":   "Complete — {0} created, {1} skipped, {2} failed."
