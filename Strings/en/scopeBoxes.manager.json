    "applyDelete":       "Delete"
  },

  "status": {
    "noHandler":      "Tool event handler unavailable — reopen the window.",
    "busy":           "An action is still running — please wait.",
    "nothingChecked": "Nothing is checked.",
    "noUnused":       "There are no unused scope boxes.",
    "scanFailed":     "Scan failed: {0}",                // {0}=message
    "aborted":        "Action aborted: {0}",             // {0}=message
    "unknownAction":  "Unknown action '{0}'.",           // {0}=token
    "boxGone":        "That scope box no longer exists — refresh.",
    "viewsSet":       "‘{0}’ — {1} view(s) assigned, {2} cleared, {3} failed.",  // name, assigned, cleared, failed
    "datumsSet":      "‘{0}’ — {1} datum(s) assigned, {2} cleared, {3} failed.", // name, assigned, cleared, failed
