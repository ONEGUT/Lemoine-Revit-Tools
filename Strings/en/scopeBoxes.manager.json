    "renameChecked": "Rename checked…",
    "deleteUnused":  "Delete unused boxes…",
    "footNote":      "Check boxes for bulk rename/delete. Deletes ask for confirmation and report what was removed."
  },

  "main": {
    "noSelection":  "Select a scope box on the left to manage it.",
    "size":         "W {0} · D {1} · H {2} ft",          // {0}/{1}/{2}=dims
    "deleteBox":    "Delete box",

    "viewsHeader":  "Views using this box  ({0})",       // {0}=count
    "assignViews":  "Assign to views…",
    "clearChecked": "Clear from checked",
