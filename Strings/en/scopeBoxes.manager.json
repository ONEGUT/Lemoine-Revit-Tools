    "datumsEmpty":  "No datums follow this scope box.",

    "kindGrid":     "Grid",
    "kindLevel":    "Level",
    "kindRefPlane": "Ref Plane"
  },

  "overlay": {
    "cancel":            "Cancel",
    "assignViewsTitle":  "Assign views to ‘{0}’",        // {0}=box name
    "assignDatumsTitle": "Assign datums to ‘{0}’",       // {0}=box name
    "applyAssign":       "Apply",
    "renameTitle":       "Rename {0} scope box(es)",      // {0}=count
    "renamePreviewTwo":  "{0}\n{1}",                      // {0}/{1}=first two new names
    "applyRename":       "Rename",
    "deleteUnusedTitle": "Delete {0} unused scope box(es)?",  // {0}=count
    "deleteBoxTitle":    "Delete ‘{0}’?",                // {0}=box name
