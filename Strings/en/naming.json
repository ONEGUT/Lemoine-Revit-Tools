{
  // Naming-token vocabulary shared by every tool that generates or rewrites names
  // (Bulk Export, Bulk Rename, Place Dependent Views, Views by Template/Link/Duplicate,
  // Bulk Views by Level, Scope Box Creator/Manager, Replicate Dependent Views, Explode
  // Views by Trade) plus the Global Settings "Naming" page.
  "tokens": {
    "sheetNumber":  { "label": "Sheet Number",  "desc": "The sheet's number." },
    "sheetName":    { "label": "Sheet Name",    "desc": "The sheet's name." },
    "revision":     { "label": "Revision",      "desc": "The sheet's current revision." },
    "issueDate":    { "label": "Issue Date",    "desc": "The sheet's issue date." },

    "viewName":     { "label": "View Name",     "desc": "The view's name." },
    "viewType":     { "label": "View Type",     "desc": "The view's type (Floor Plan, 3D, Section…)." },
    "level":        { "label": "Level",         "desc": "The view's associated level." },

    "currentName":  { "label": "Current Name",  "desc": "The element's existing name, unchanged." },

    "sourceViewName":  { "label": "Source View Name", "desc": "The name of the source/parent view this item was created from." },
    "parentViewName":  { "label": "Parent View",      "desc": "The name of the parent view this item was created from." },
    "templateName":    { "label": "Template Name",    "desc": "The name of the view template applied." },
    "linkName":        { "label": "Link Name",        "desc": "The name of the linked model this item was created from." },

    "projectNumber": { "label": "Project No.",   "desc": "The project's number, from Project Information." },
    "projectName":   { "label": "Project Name",  "desc": "The project's name, from Project Information." },

    "year":  { "label": "Year",  "desc": "The current year (yyyy)." },
    "month": { "label": "Month", "desc": "The current month (MM)." },
    "day":   { "label": "Day",   "desc": "The current day (dd)." },

    "seq":   { "label": "Counter", "desc": "A running counter for this run, formatted per the tool's counter settings." }
  },

  // Tool-specific Computed tokens — meaningful only within their own tool, so they are
  // declared beside each ViewModel rather than in the global registry, but their
  // display labels still live here for consistency with everything else user-facing.
  "computed": {
    "byLevel": {
      "levelName": { "label": "Level Name" },
      "scopeBox":  { "label": "Scope Box" }
    },
    "scopeBoxes": {
      "buildingLetter": { "label": "Building Letter" },
      "levelName":       { "label": "Level Name" },
      "levelRange":      { "label": "Level Range" },
      "modelName":       { "label": "Model Name" }
    },
    "scopeBoxManagerRename": {
      "number": { "label": "Number" }
    },
    "replicateDependent": {
      "hostLevel":      { "label": "Host Level" },
      "targetViewName": { "label": "Target View Name" },
      "depSuffix":      { "label": "Dep Suffix" }
    },
    "explodeByTrade": {
      "counter":    { "label": "Counter" },
      "sourceView": { "label": "Source View" },
      "trade":      { "label": "Trade" }
    },
    "placeDependentViews": {
      "sheetNumber": { "label": "Sheet Number (new)" }
    }
  },

  "input": {
    "reset": "Reset to default",
    "previewLabel": "Preview:",
    "previewEmpty": "(empty name)",
    "groupTarget": "This item",
    "groupSource": "Source",
    "groupProject": "Project",
    "groupDate": "Date & Counter",
    "groupUser": "Your tokens"
  },

  "resolver": {
    "unknownToken": "Unknown token {0} left as-is",
    "missingParam": "Token {0}: parameter '{1}' not found on '{2}' — used fallback '{3}'",
    "missingSubject": "Token {0} ({1}): no element to read from — used fallback",
    "degenerate": "Name pattern resolved to '{0}', which has no usable characters — used '{1}' instead"
  },

  // Global Settings "Naming" tab — built here even though the page UI itself is a
  // later phase, since the core (ParameterCatalog, UserTokenStore.Validate) already
  // references these keys.
  "settings": {
    "paramOrigin": {
      "project": "Project parameter",
      "shared":  "Shared parameter",
      "builtIn": "Built-in (common)"
    },
    "errors": {
      "invalid":            "That token isn't valid.",
      "keyEmpty":           "Give the token a name.",
      "keyTooLong":         "Keep the token key to {0} characters or fewer.",
      "keyCharset":         "Token keys can only use letters, numbers, and underscores, and must start with a letter.",
      "keyReserved":        "'{0}' is already a built-in token — choose a different name.",
      "keyDuplicate":       "You already have a token named '{0}'.",
      "labelEmpty":         "Give the token a display label.",
      "guidInvalid":        "That doesn't look like a valid parameter GUID.",
      "parameterRequired":  "Pick a parameter, or enter one manually."
    }
  }
}
