<Window
    x:Class="LemoineTools.Lemoine.LemoineSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="Lemoine Tools — Settings"
    Width="420" Height="540"
    MinWidth="360" MinHeight="420"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    ResizeMode="CanResizeWithGrip"
    AllowsTransparency="False"
    ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            ResizeBorderThickness="4"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="_outerBorder" BorderThickness="1">
        <Grid x:Name="_root">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*"  />
                <RowDefinition Height="48" />
            </Grid.RowDefinitions>

            <Border x:Name="_toolbarBorder"  Grid.Row="0" BorderThickness="0,0,0,1" />
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,8,12,8">
                <StackPanel x:Name="_settingsStack" />
            </ScrollViewer>
            <Border x:Name="_footerBorder" Grid.Row="2" BorderThickness="0,1,0,0" Padding="{DynamicResource LemoineTh_FooterPad}" />
        </Grid>
    </Border>
</Window>
