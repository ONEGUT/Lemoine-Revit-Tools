<UserControl
    x:Class="LemoineTools.Lemoine.Controls.LemoineFileBrowser"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <!-- Optional label -->
        <TextBlock x:Name="_label"
                   TextWrapping="Wrap"
                   Margin="0,0,0,7"
                   Visibility="Collapsed" />

        <!-- Path input + Browse button -->
        <DockPanel>
            <Button x:Name="_browseBtn"
                    DockPanel.Dock="Right"
                    Content="Browse…"
                    Click="Browse_Click"
                    Padding="12,0"
                    Margin="6,0,0,0"
                    Cursor="Hand" />

            <TextBox x:Name="_pathBox"
                     Padding="7,5"
                     VerticalContentAlignment="Center"
                     BorderThickness="1"
                     TextChanged="PathBox_TextChanged" />
        </DockPanel>
    </StackPanel>
</UserControl>
