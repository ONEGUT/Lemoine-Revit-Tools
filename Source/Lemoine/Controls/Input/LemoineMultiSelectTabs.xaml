<UserControl
    x:Class="LemoineTools.Lemoine.Controls.LemoineMultiSelectTabs"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderThickness="1" CornerRadius="{DynamicResource LemoineRadius_MD}" MinHeight="120">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="80" MaxWidth="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: group tabs -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="_tabStack" />
                </ScrollViewer>
            </Border>

            <!-- Right: checkboxes for active group -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="8,8,8,4">
                <StackPanel x:Name="_checkStack" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
