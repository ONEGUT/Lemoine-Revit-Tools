<UserControl
    x:Class="LemoineTools.Lemoine.Controls.LemoineTextField"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <!-- Optional label -->
        <TextBlock x:Name="_label"
                   TextWrapping="Wrap"
                   Margin="0,0,0,7"
                   Visibility="Collapsed" />

        <!-- Text input + watermark overlay -->
        <Grid>
            <TextBox x:Name="_textBox"
                     Padding="8,6,10,6"
                     BorderThickness="1"
                     VerticalContentAlignment="Center" />
            <!-- Watermark — visible when the TextBox is empty. Left inset matches the
                 typed-text origin: BorderThickness(1) + Padding.Left(8) via Margin, plus
                 Padding="2,0" to match the editable text host's caret inset (same trick the
                 DatePickerTextBox watermark uses), so the watermark and typed text align. -->
            <TextBlock x:Name="_placeholder"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="9,0,10,0"
                       Padding="2,0"
                       Opacity="0.55"
                       Visibility="Collapsed" />
        </Grid>
    </StackPanel>
</UserControl>
