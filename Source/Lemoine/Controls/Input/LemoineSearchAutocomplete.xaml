<UserControl
    x:Class="LemoineTools.Lemoine.Controls.LemoineSearchAutocomplete"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="_root">
        <!-- TextBox + search icon + placeholder -->
        <Grid>
            <TextBox x:Name="_textBox"
                     Padding="30,6,10,6"
                     BorderThickness="1"
                     VerticalContentAlignment="Center" />
            <!-- Search icon drawn in code-behind as a Path -->
            <Canvas x:Name="_iconCanvas" Width="12" Height="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="9,0,0,0"
                    IsHitTestVisible="False" />
            <!-- Placeholder watermark — visible when TextBox is empty -->
            <TextBlock x:Name="_placeholder"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="30,0,10,0"
                       Opacity="0.55"
                       Visibility="Collapsed" />
        </Grid>

        <!-- Dropdown popup — anchors to this control -->
        <Popup x:Name="_popup"
               PlacementTarget="{Binding ElementName=_textBox}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border x:Name="_dropdownBorder"
                    MaxHeight="220"
                    MinWidth="200"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LemoineRadius_MD}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="_dropStack" />
                </ScrollViewer>
            </Border>
        </Popup>
    </Grid>
</UserControl>
