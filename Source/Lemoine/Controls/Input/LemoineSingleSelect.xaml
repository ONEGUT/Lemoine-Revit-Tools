<UserControl
    x:Class="LemoineTools.Lemoine.Controls.LemoineSingleSelect"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <TextBlock x:Name="_label" Margin="0,0,0,6" Visibility="Collapsed"
                   TextWrapping="Wrap" />
        <ComboBox x:Name="_combo"
                  SelectionChanged="Combo_SelectionChanged"
                  AutomationProperties.LabeledBy="{Binding ElementName=_label}" />
    </StackPanel>
</UserControl>
