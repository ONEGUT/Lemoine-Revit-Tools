<UserControl
    x:Class="LemoineTools.Lemoine.Controls.LemoineInlineStepper"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="_outer" BorderThickness="1" CornerRadius="{DynamicResource LemoineRadius_SM}"
            ClipToBounds="True" SnapsToDevicePixels="True" VerticalAlignment="Center">
        <StackPanel x:Name="_root" Orientation="Horizontal" />
    </Border>
</UserControl>
