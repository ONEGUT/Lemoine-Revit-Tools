<UserControl
    x:Class="LemoineTools.Lemoine.Controls.LemoineBrowserTreePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="_outer" BorderThickness="1" CornerRadius="{DynamicResource LemoineRadius_MD}" MinHeight="160">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Filter row: search box + expand/collapse-all -->
            <Grid Grid.Row="0" Margin="8,8,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="_filterBox" VerticalContentAlignment="Center" />
                    <TextBlock x:Name="_filterHint"
                               Margin="9,0,0,0"
                               VerticalAlignment="Center"
                               FontStyle="Italic"
                               IsHitTestVisible="False" />
                </Grid>
                <StackPanel x:Name="_filterBtns" Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0" />
            </Grid>

            <!-- The browser-mirroring tree -->
            <ScrollViewer x:Name="_treeScroll" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6,0,6,4">
                <StackPanel x:Name="_treeStack" />
            </ScrollViewer>

            <!-- Footer: selection count + clear -->
            <Border x:Name="_footer" BorderThickness="0,1,0,0" Grid.Row="2" Padding="10,6,10,6">
                <DockPanel x:Name="_footerPanel" LastChildFill="False" />
            </Border>
        </Grid>
    </Border>
</UserControl>
