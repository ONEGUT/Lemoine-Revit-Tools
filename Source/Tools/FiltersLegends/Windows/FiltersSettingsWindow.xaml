<Window
    x:Class="LemoineTools.Framework.FiltersSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="Lemoine Tools — Auto Filters"
    Width="1100" Height="700"
    MinWidth="860" MinHeight="500"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResizeWithGrip"
    AllowsTransparency="False"
    ShowInTaskbar="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="8"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="_outerBorder" BorderThickness="1" ClipToBounds="True">
        <Grid x:Name="_root">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*"  />
            </Grid.RowDefinitions>

            <Border x:Name="_toolbarBorder" Grid.Row="0" ClipToBounds="True" />
            <Grid Grid.Row="1">
                <Border x:Name="_contentBorder" />
                <!-- Floating bottom-right transient status chip. -->
                <ContentControl x:Name="_floatingSlot"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Panel.ZIndex="50" Margin="0,0,16,16" />
            </Grid>
        </Grid>
    </Border>
</Window>
